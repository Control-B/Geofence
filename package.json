{
  "name": "warehouse-geofence-checkin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:checkin": "tsx services/checkin-service/src/index.ts",
    "dev:dashboard": "tsx services/dashboard-service/src/index.ts",
    "dev:docs": "tsx services/docs-service/src/index.ts",
    "dev:signing": "tsx services/signing-service/src/index.ts",
    "service:checkin": "node --import tsx services/checkin-service/src/index.ts",
    "service:dashboard": "node --import tsx services/dashboard-service/src/index.ts",
    "service:docs": "node --import tsx services/docs-service/src/index.ts",
    "service:signing": "node --import tsx services/signing-service/src/index.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:schema": "psql \"$DATABASE_URL\" -f db/schema.sql",
    "db:seed": "psql \"$DATABASE_URL\" -f db/seed.sql"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.583.0",
    "@aws-sdk/s3-request-presigner": "^3.583.0",
    "@clerk/backend": "^3.4.9",
    "@clerk/nextjs": "^7.3.5",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "next": "^16.2.6",
    "pg": "^8.11.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^10.4.0",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}
