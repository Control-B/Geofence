FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src
COPY backend/FreightCheckIn.Api/FreightCheckIn.Api.csproj backend/FreightCheckIn.Api/
RUN dotnet restore backend/FreightCheckIn.Api/FreightCheckIn.Api.csproj
COPY backend/FreightCheckIn.Api backend/FreightCheckIn.Api
RUN dotnet publish backend/FreightCheckIn.Api/FreightCheckIn.Api.csproj -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*
COPY --from=build /app/publish .
ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080
ENTRYPOINT ["dotnet", "FreightCheckIn.Api.dll"]
