NEXT_PUBLIC_APP_URL=http://localhost:3000

# Browser-facing microservice URLs for local Docker Compose.
# In production, use each service's public/internal gateway URL.
NEXT_PUBLIC_CHECKIN_API_URL=http://localhost:4001
NEXT_PUBLIC_DASHBOARD_API_URL=http://localhost:4002
NEXT_PUBLIC_DOCS_API_URL=http://localhost:4003
NEXT_PUBLIC_SIGNING_API_URL=http://localhost:4004
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
NEXT_PUBLIC_MAPBOX_TOKEN=pk_replace_me

# Server-side CORS allowlist for services
CORS_ORIGIN=http://localhost:3000

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-in

# Local development only: bypass Clerk for the warehouse operations dashboard.
# Keep this false or unset in production.
DEV_AUTH_BYPASS=false
NEXT_PUBLIC_DEV_AUTH_BYPASS=false

# DigitalOcean Managed PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:25060/defaultdb?sslmode=require
POSTGRES_HOST_PORT=15433

# DigitalOcean Managed Redis connection string
REDIS_URL=rediss://default:password@host:25061

# ASP.NET Core freight arrival API / Azure integrations
PUBLIC_APP_BASE_URL=http://localhost:3000
ACS_CONNECTION_STRING=endpoint=https://replace-me.communication.azure.com/;accesskey=replace_me
ACS_FROM_NUMBER=+15555550123
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://replace-me.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=replace_me
TRIP_EVENTS_QUEUE_NAME=trip-events
AZURE_BLOB_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=replace;AccountKey=replace;EndpointSuffix=core.windows.net
AZURE_BLOB_STORAGE_CONTAINER_NAME=delivery-documents
TEAMS_BOT_MICROSOFT_APP_ID=
TEAMS_BOT_MICROSOFT_APP_PASSWORD=
TEAMS_BOT_TENANT_ID=
TEAMS_BOT_TARGET_CONVERSATION_ID=

# Optional DigitalOcean Spaces private document storage
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=warehouse-checkins
DO_SPACES_KEY=replace_me
DO_SPACES_SECRET=replace_me

# Upload and token controls
TOKEN_TTL_HOURS=72
MAX_UPLOAD_BYTES=10485760
